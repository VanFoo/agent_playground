# Copy this file to .env and fill in real values before starting.
#   cp .env.example .env

# Absolute path on the HOST to the project you want to develop on.
# Mounted into the devcontainer at /workspace.
#   Linux/Mac example: /home/yourname/code/myproject
#   Windows example:   C:/Users/yourname/code/myproject   (forward slashes,
#                       even on Windows)
HOST_PROJECT_PATH=/path/to/your/project
